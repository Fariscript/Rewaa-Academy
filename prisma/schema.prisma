// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// Roles table, CLAUDE.md. Two roles only for now — ADMIN currently covers
// what would be a separate Trainer/Training Manager role too (question-bank
// approval, manual grading, dashboard), until/unless that splits out later.
// Trainee — sector-scoped content + quizzes only
// ADMIN   — manages taxonomy, assigns/reassigns trainees to sectors, can
//           override attempts, approves question bank, grades manual
//           submissions, views testing dashboard
enum Role {
  TRAINEE
  ADMIN
}

// FR-02, FR-03, T-27: identity comes from Google Workspace SSO only, restricted
// to the company domain — there is no separate password auth for this platform.
model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  image         String?
  emailVerified DateTime?
  role          Role      @default(TRAINEE)

  // FR-07: a trainee is assigned to a sector by an Admin. Null until assigned.
  sectorId String?
  sector   Sector? @relation(fields: [sectorId], references: [id])

  accounts          Account[]
  sessions          Session[]
  auditLogs         AuditLog[]
  lessonCompletions LessonCompletion[]
  attempts          Attempt[]
  createdQuestions  Question[]         @relation("QuestionCreatedBy")
  approvedQuestions Question[]         @relation("QuestionApprovedBy")
  questionRevisions QuestionRevision[]
  gradedAnswers     AttemptAnswer[]    @relation("AttemptAnswerGradedBy")
  certificates      Certificate[]

  attemptCapOverrides        AttemptCapOverride[] @relation("AttemptCapOverrideUser")
  grantedAttemptCapOverrides AttemptCapOverride[] @relation("AttemptCapOverrideGrantedBy")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("users")
}

// --- Sector-scoped content model (stub) -------------------------------
// Ibrahim's content system owns real content authoring; this is just enough
// structure for the testing engine to depend on (sector-scoped access,
// lesson-complete tracking in slice 3, question tagging in slice 5).
// Hierarchy follows NFR-10: Sector -> Sub-sector -> Skill Type (-> Unit).

// FR-05: top-level sectors (Services, Retail, Restaurants & Cafés, ...).
model Sector {
  id           String        @id @default(cuid())
  name         String        @unique
  subSectors   SubSector[]
  trainees     User[]
  certificates Certificate[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("sectors")
}

// FR-06: sectors are broken into sub-sectors.
model SubSector {
  id       String @id @default(cuid())
  name     String
  sectorId String
  sector   Sector @relation(fields: [sectorId], references: [id], onDelete: Cascade)
  units    Unit[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([sectorId, name])
  @@map("sub_sectors")
}

// FR-08: two fixed categories per sector, Soft Skills and Hard Skills.
enum SkillType {
  SOFT
  HARD
}

// FR-09/FR-10/T-14: a named topic/subcategory under a skill type (e.g. "أول
// مكالمة" under Soft Skills). This is the tagging granularity the question
// bank (slice 5) and quiz assembly (slice 4, T-16) key off — sector and
// skill type are both reachable from a Unit via subSector.sector + skillType.
model Unit {
  id          String    @id @default(cuid())
  name        String
  skillType   SkillType
  subSectorId String
  subSector   SubSector @relation(fields: [subSectorId], references: [id], onDelete: Cascade)
  lessons     Lesson[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([subSectorId, name])
  @@map("units")
}

// FR-12 stub: the real content item (video/PDF/article) lives in Ibrahim's
// content system — this row is just enough for lesson-complete tracking
// (slice 3) to key off.
model Lesson {
  id     String @id @default(cuid())
  title  String
  unitId String
  unit   Unit   @relation(fields: [unitId], references: [id], onDelete: Cascade)

  completions LessonCompletion[]
  quiz        Quiz?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("lessons")
}

// T-7 (write half): a trainee's completion of a single lesson. This is the
// signal quiz-unlock (below) reads — see src/lib/content/quiz-unlock.ts.
model LessonCompletion {
  id       String @id @default(cuid())
  userId   String
  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  lessonId String
  lesson   Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  completedAt DateTime @default(now())

  @@unique([userId, lessonId])
  @@map("lesson_completions")
}

// T-1: one pop quiz per lesson.
model Quiz {
  id       String @id @default(cuid())
  lessonId String @unique
  lesson   Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  title    String

  // T-32: every quiz has a visible countdown timer.
  timeLimitSeconds Int @default(600)

  questions Question[]
  attempts  Attempt[]

  attemptCapOverrides AttemptCapOverride[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("quizzes")
}

// T-17: MCQ/TRUE_FALSE are auto-graded. T-18: SCENARIO/FREE_TEXT/MOCK_CALL
// have no fixed correct answer and are routed to manual grading instead —
// see src/lib/questions/question-types.ts for the auto-graded/manual split
// used throughout scoring, validation, and the grading queue. Question is
// quiz-owned; T-14's sector/skill-type/unit tags stay derivable via
// quiz.lesson.unit rather than being duplicated here.
enum QuestionType {
  MCQ
  TRUE_FALSE
  SCENARIO
  FREE_TEXT
  MOCK_CALL
}

// T-10/T-11/T-12/NFR-06: every question starts DRAFT regardless of origin —
// AI-drafted and manually-authored both require the same explicit approve
// step (CLAUDE.md "Slice 5 decisions"). Editing an APPROVED question resets
// it to DRAFT, requiring fresh approval — no auto-publish path, no
// exceptions. REJECTED is permanent and distinct from RETIRED (a question
// that was once approved and later withdrawn).
enum QuestionStatus {
  DRAFT
  APPROVED
  RETIRED
  REJECTED
}

enum QuestionSource {
  MANUAL
  AI_DRAFT
}

model Question {
  id     String       @id @default(cuid())
  quizId String
  quiz   Quiz         @relation(fields: [quizId], references: [id], onDelete: Cascade)
  type   QuestionType
  prompt String

  // MCQ: [{id, text}, ...]. TRUE_FALSE: [{id:"true",text:"..."},{id:"false",text:"..."}].
  // Null for SCENARIO/FREE_TEXT/MOCK_CALL — no fixed options or answer key.
  options       Json?
  correctOption String?

  status QuestionStatus @default(DRAFT)
  source QuestionSource @default(MANUAL)

  createdById  String?
  createdBy    User?     @relation("QuestionCreatedBy", fields: [createdById], references: [id])
  approvedById String?
  approvedBy   User?     @relation("QuestionApprovedBy", fields: [approvedById], references: [id])
  approvedAt   DateTime?

  attemptAnswers AttemptAnswer[]
  revisions      QuestionRevision[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("questions")
}

// T-15/NFR-13: append-only pre-edit snapshot, taken before each edit is
// applied to the live Question row above — "prior versions viewable" reads
// from here. "Restorable" re-enters the normal edit path (archives current
// content as a new revision, applies the chosen old content, resets status
// to DRAFT) rather than being a special bypass.
model QuestionRevision {
  id         String   @id @default(cuid())
  questionId String
  question   Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  type          QuestionType
  prompt        String
  options       Json?
  correctOption String?
  status        QuestionStatus

  editedById String?
  editedBy   User?   @relation(fields: [editedById], references: [id])

  createdAt DateTime @default(now())

  @@map("question_revisions")
}

// PENDING_MANUAL_GRADE: T-18 — an attempt containing at least one
// SCENARIO/FREE_TEXT/MOCK_CALL answer is routed here on submit instead of
// being scored immediately. There is deliberately no path from this status
// to SUBMITTED/AUTO_SUBMITTED yet: converting graded items into an overall
// score/passed (T-26) depends on CLAUDE.md open item #4 (does manual
// grading hit the same 95% bar, or is it Admin judgment?), which is
// unresolved. See src/lib/grading/.
enum AttemptStatus {
  IN_PROGRESS
  SUBMITTED
  AUTO_SUBMITTED
  PENDING_MANUAL_GRADE
}

// Roles table (CLAUDE.md): Admin "can override attempts". Each row grants
// one trainee extra attempts on one quiz beyond the immutable default cap
// of 2 (T-3/T-20 — the default itself never changes; see
// src/lib/admin/attempt-override.ts). Grants are append-only with a reason,
// so the full override history stays auditable alongside the AuditLog entry.
// Deliberately does NOT decide open item #1 (what happens after both
// attempts fail): a grant simply raises the cap, which returns the trainee
// to attempts-remaining.
model AttemptCapOverride {
  id            String @id @default(cuid())
  userId        String
  user          User   @relation("AttemptCapOverrideUser", fields: [userId], references: [id], onDelete: Cascade)
  quizId        String
  quiz          Quiz   @relation(fields: [quizId], references: [id], onDelete: Cascade)
  extraAttempts Int    @default(1)
  reason        String
  grantedById   String
  grantedBy     User   @relation("AttemptCapOverrideGrantedBy", fields: [grantedById], references: [id])

  createdAt DateTime @default(now())

  @@index([userId, quizId])
  @@map("attempt_cap_overrides")
}

// T-19: trainee id, quiz id, timestamp, answers, score, outcome all live
// here. T-3/T-20: attemptNumber is capped at 2 by application logic plus a
// unique constraint as a defense-in-depth backstop against a race.
model Attempt {
  id            String        @id @default(cuid())
  userId        String
  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  quizId        String
  quiz          Quiz          @relation(fields: [quizId], references: [id], onDelete: Cascade)
  attemptNumber Int
  status        AttemptStatus @default(IN_PROGRESS)

  startedAt   DateTime  @default(now())
  submittedAt DateTime?

  // Null until finalized (SUBMITTED or AUTO_SUBMITTED).
  score  Float?
  passed Boolean?

  answers AttemptAnswer[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, quizId, attemptNumber])
  @@map("attempts")
}

// NFR-13/T-15: question content is snapshotted at attempt-start, not
// live-referenced — editing a Question later (slice 5) must never change
// what a completed attempt was scored or is displayed against. questionId
// is a soft traceability link only (SetNull on delete/retire).
model AttemptAnswer {
  id         String    @id @default(cuid())
  attemptId  String
  attempt    Attempt   @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  questionId String?
  question   Question? @relation(fields: [questionId], references: [id], onDelete: SetNull)

  questionPrompt String
  questionType   QuestionType
  options        Json?
  correctOption  String?

  // MCQ/TRUE_FALSE:
  selectedOption String?
  // SCENARIO/FREE_TEXT/MOCK_CALL — T-18: the trainee's written response.
  textAnswer     String?

  // Auto-graded (MCQ/TRUE_FALSE): set immediately at finalize time.
  // Manually-graded: null until an Admin grades it (T-25) — see
  // src/lib/grading/. Reused as the per-item correctness judgment either
  // way, but nothing yet converts a manual grade into the attempt's
  // overall score/passed (T-26, open item #4).
  isCorrect Boolean?
  feedback  String?

  gradedById String?
  gradedBy   User?     @relation("AttemptAnswerGradedBy", fields: [gradedById], references: [id])
  gradedAt   DateTime?

  @@unique([attemptId, questionId])
  @@map("attempt_answers")
}

// T-4/T-28/NFR-18: issued once a trainee has passed every quiz in their
// (current, at issuance time) sector. One per (user, sector) — issuing is
// idempotent, re-checking eligibility after issuance just returns the
// existing row rather than creating a duplicate. traineeName is a snapshot
// (T-28 "pulls name... from the SSO identity profile" — User.name, sourced
// from Google SSO at login) so a later name change doesn't retroactively
// alter an already-issued certificate. signature is an Ed25519 signature
// over the row's own canonical fields (src/lib/certificates/signing.ts) —
// verifiable proof the record hasn't been tampered with since issuance.
model Certificate {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  sectorId String
  sector   Sector @relation(fields: [sectorId], references: [id])

  traineeName    String
  completionDate DateTime
  signature      String

  issuedAt DateTime @default(now())

  @@unique([userId, sectorId])
  @@map("certificates")
}

// NFR-05: audit trail of Admin actions (user creation, sector/role
// assignment, content changes...). Introduced here for the first real admin
// mutation (sector reassignment); slice 4's attempt overrides and slice 5's
// question approvals reuse this.
model AuditLog {
  id         String   @id @default(cuid())
  actorId    String
  actor      User     @relation(fields: [actorId], references: [id])
  action     String
  targetType String
  targetId   String
  metadata   Json?

  createdAt DateTime @default(now())

  @@map("audit_logs")
}

// Standard Auth.js (NextAuth v5) Prisma adapter models below.
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

// Database session strategy (not JWT): lets us look up, and forcibly expire,
// a trainee's session server-side — required for NFR-04 (session timeout /
// re-authentication after prolonged inactivity).
model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}
