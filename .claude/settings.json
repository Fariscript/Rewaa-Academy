{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/session-start.sh"
          }
        ]
      }
    ]
  },
  "permissions": {
    "deny": [
      "Bash(git push * main)",
      "Bash(git push --force*)",
      "Bash(git push -f *)",
      "Bash(npx prisma migrate reset*)",
      "Bash(npx prisma db push --force-reset*)",
      "Edit(**/signing.ts)",
      "Edit(**/signing-config.ts)",
      "Edit(**/instrumentation.ts)",
      "Edit(**/auth.ts)",
      "Edit(**/*.pem)",
      "Edit(**/*.key)",
      "Edit(.env)",
      "Edit(.env.test)"
    ]
  }
}
