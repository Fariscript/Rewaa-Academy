DATABASE_URL="postgresql://user@localhost:5432/rewaa_academy_dev?schema=public"

# Auth.js (NextAuth v5) — https://authjs.dev
AUTH_SECRET="generate-with: npx auth secret"
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# Restrict Google Workspace SSO to this domain (FR-02, FR-03).
ALLOWED_GOOGLE_WORKSPACE_DOMAIN="example.com"

# AI question drafting (T-10) — https://docs.claude.com/en/api/overview
ANTHROPIC_API_KEY=""
ANTHROPIC_MODEL="claude-sonnet-5"

# Certificate digital signature (NFR-18) — Ed25519 private key, PEM with
# literal \n escapes on a single line. DO NOT paste the multi-line PEM
# output of a plain `privateKey.export(...)` here — dotenv/@next/env parse
# .env line-by-line, so a raw multi-line paste silently truncates to just
# the "-----BEGIN PRIVATE KEY-----" line and every downstream sign/verify
# call fails with an opaque OpenSSL decoder error. Generate a paste-ready
# line (already escaped, already quoted) with:
#   node -e "const {generateKeyPairSync}=require('node:crypto');const {privateKey}=generateKeyPairSync('ed25519');console.log('CERTIFICATE_SIGNING_PRIVATE_KEY=\"'+privateKey.export({type:'pkcs8',format:'pem'}).trim().replace(/\n/g,'\\\\n')+'\"')"
# Copy the ENTIRE printed line (including the CERTIFICATE_SIGNING_PRIVATE_KEY= prefix) over the line below.
CERTIFICATE_SIGNING_PRIVATE_KEY=""

# Staging-only quick-login (Admin/Trainee buttons on /login, forged sessions
# for the seeded fixture users — no Google OAuth round-trip). Never set this
# on a real production deploy — src/lib/dev/staging-quick-login.ts also
# refuses to activate under Netlify's own production build context as a
# fail-safe, but that check shouldn't be the only thing standing between
# this and production. Leave unset/false outside a Netlify staging deploy.
STAGING_QUICK_LOGIN_ENABLED="false"
